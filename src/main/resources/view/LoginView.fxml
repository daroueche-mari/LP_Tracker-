<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="controller.LoginController" style="-fx-background-color: #f4f4f4;">
    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Connexion LP Tracker" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
    
    <TextField fx:id="usernameField" promptText="Nom d'utilisateur" maxWidth="250"/>
    <PasswordField fx:id="passwordField" promptText="Mot de passe" maxWidth="250"/>
    
    <Button text="Se connecter" onAction="#handleLogin" 
        style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;" 
        prefWidth="250" maxWidth="250"/>
            
    <Label fx:id="errorLabel" text="" style="-fx-text-fill: red;"/>
</VBox>