<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="600.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.WelcomeController">
   <children>
      
      <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #2c3e50;" HBox.hgrow="ALWAYS">
         <padding>
            <Insets left="60.0" right="60.0" />
         </padding>
         <children>
            <Label text="NOUVEAU ICI ?" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="32.0" />
               </font>
            </Label>
            <Label text="Créez votre compte pour commencer" textFill="#bdc3c7">
               <VBox.margin>
                  <Insets bottom="20.0" />
               </VBox.margin>
            </Label>
            
            <TextField fx:id="regUserField" prefHeight="45.0" promptText="Nom d'utilisateur" 
                       style="-fx-background-radius: 10; -fx-background-color: #34495e; -fx-text-fill: white; -fx-prompt-text-fill: #95a5a6;" />
            
            <PasswordField fx:id="regPassField" prefHeight="45.0" promptText="Mot de passe" 
                           style="-fx-background-radius: 10; -fx-background-color: #34495e; -fx-text-fill: white; -fx-prompt-text-fill: #95a5a6;" />
            
            <PasswordField fx:id="regConfirmField" prefHeight="45.0" promptText="Confirmer mot de passe" 
                           style="-fx-background-radius: 10; -fx-background-color: #34495e; -fx-text-fill: white; -fx-prompt-text-fill: #95a5a6;" />
            
            <Button mnemonicParsing="false" onAction="#handleRegister" prefHeight="45.0" prefWidth="250.0" 
                    onMouseEntered="#handleHoverEnterSide" onMouseExited="#handleHoverExitSide"
                    style="-fx-background-color: transparent; -fx-border-color: white; -fx-border-radius: 25; -fx-text-fill: white; -fx-cursor: hand;" 
                    text="CRÉER UN COMPTE">
               <font><Font name="System Bold" size="14.0" /></font>
               <VBox.margin><Insets top="15.0" /></VBox.margin>
            </Button>
         </children>
      </VBox>

      <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #e67e22;" HBox.hgrow="ALWAYS">
         <padding>
            <Insets left="60.0" right="60.0" />
         </padding>
         <children>
            <Label text="BIENVENUE" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="40.0" />
               </font>
            </Label>
            <Label text="Connectez-vous à LP Tracker" textFill="WHITE">
               <VBox.margin>
                  <Insets bottom="20.0" />
               </VBox.margin>
            </Label>
            
            <TextField fx:id="loginUserField" prefHeight="45.0" promptText="Utilisateur" 
                       style="-fx-background-radius: 10; -fx-background-color: #d35400; -fx-text-fill: white; -fx-prompt-text-fill: #f39c12;" />
            
            <PasswordField fx:id="loginPassField" prefHeight="45.0" promptText="Mot de passe" 
                           style="-fx-background-radius: 10; -fx-background-color: #d35400; -fx-text-fill: white; -fx-prompt-text-fill: #f39c12;" />
            
            <Button mnemonicParsing="false" onAction="#handleLogin" prefHeight="45.0" prefWidth="250.0" 
                    onMouseEntered="#handleHoverEnterGreen" onMouseExited="#handleHoverExitGreen"
                    style="-fx-background-color: white; -fx-text-fill: #e67e22; -fx-background-radius: 25; -fx-cursor: hand; -fx-font-weight: bold;" 
                    text="SE CONNECTER">
               <font><Font name="System Bold" size="14.0" /></font>
               <VBox.margin><Insets top="15.0" /></VBox.margin>
            </Button>
         </children>
      </VBox>
      
   </children>
</HBox>