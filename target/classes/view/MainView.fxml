<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750.0" prefWidth="1100.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.StudentController">
   
   <left>
      <VBox prefWidth="250.0" spacing="15.0" style="-fx-background-color: #2c3e50;">
         <padding><Insets bottom="20" left="15" right="15" top="30" /></padding>
         <children>
            <Label text="LP TRACKER" textFill="WHITE">
               <font><Font name="System Bold" size="24.0" /></font>
               <VBox.margin><Insets bottom="30" /></VBox.margin>
            </Label>
            
            <Label style="-fx-font-size: 10; -fx-font-weight: bold;" text="EXPORTS &amp; IMPORTS" textFill="#bdc3c7" />
            
            <Button onAction="#handleExportCSV" prefWidth="220" styleClass="sidebar-button" text="📥 Exporter CSV" />
            <Button onAction="#handleImportCSV" prefWidth="220" styleClass="sidebar-button" text="📤 Importer CSV" />
            <Button onAction="#handleExportJSON" prefWidth="220" styleClass="sidebar-button" text="📦 Exporter JSON" />
            <Button onAction="#handleExportXML" prefWidth="220" styleClass="sidebar-button" text="📂 Exporter XML" />
            <Button onAction="#handleExportHTML" prefWidth="220" styleClass="sidebar-button" text="📄 Rapport PDF / HTML" />
            
            <Region VBox.vgrow="ALWAYS" />
            
            <Button onAction="#handleLogout" prefWidth="220" styleClass="btn-logout" text="🚪 Déconnexion" />
         </children>
      </VBox>
   </left>

   <center>
      <VBox spacing="20.0" style="-fx-background-color: #f4f7f6;">
         <padding><Insets bottom="25" left="25" right="25" top="25" /></padding>
         <children>
            
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
               <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
               <children>
                  <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="Gestion de l'étudiant" textFill="#2c3e50" />
                  <GridPane hgap="15" vgap="15">
                     <children>
                        <TextField fx:id="fNameInput" prefHeight="35" promptText="Prénom" style="-fx-background-radius: 5;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="lNameInput" prefHeight="35" promptText="Nom" style="-fx-background-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <TextField fx:id="ageInput" prefHeight="35" promptText="Âge" style="-fx-background-radius: 5;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <TextField fx:id="gradeInput" prefHeight="35" promptText="Note" style="-fx-background-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                     </children>
                     <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" />
                        <ColumnConstraints hgrow="SOMETIMES" />
                     </columnConstraints>
                     <rowConstraints>
                        <RowConstraints vgrow="SOMETIMES" />
                        <RowConstraints vgrow="SOMETIMES" />
                     </rowConstraints>
                  </GridPane>
                  <HBox alignment="CENTER_RIGHT" spacing="10">
                     <Button onAction="#handleDeleteStudent" styleClass="btn-delete" text="🗑️ Supprimer" />
                     <Button onAction="#handleUpdateStudent" styleClass="btn-update" text="🔄 Modifier" />
                     <Button onAction="#handleAddStudent" prefWidth="120" styleClass="btn-add" text="➕ Ajouter" />
                  </HBox>
               </children>
            </VBox>

            <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
               <children>
                  <VBox spacing="5">
                     <Label style="-fx-font-size: 11; -fx-text-fill: #7f8c8d;" text="Prénom" />
                     <TextField fx:id="searchFirstName" prefWidth="150" promptText="Rechercher..." style="-fx-background-radius: 5;" />
                  </VBox>
                  <VBox spacing="5">
                     <Label style="-fx-font-size: 11; -fx-text-fill: #7f8c8d;" text="Nom" />
                     <TextField fx:id="searchLastName" prefWidth="150" promptText="Rechercher..." style="-fx-background-radius: 5;" />
                  </VBox>
                  <VBox spacing="5">
                     <Label style="-fx-font-size: 11; -fx-text-fill: #7f8c8d;" text="Âge" />
                     <ComboBox fx:id="ageFilterCombo" prefWidth="100" style="-fx-background-radius: 5;" />
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button onAction="#handleResetFilters" prefHeight="35" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5; -fx-font-weight: bold;" text="🔄 Réinitialiser" />
               </children>
            </HBox>

            <TableView fx:id="studentTable" onMouseClicked="#handleTableClick" style="-fx-background-radius: 10; -fx-background-color: white;" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colFirstName" prefWidth="200" text="Prénom" />
                  <TableColumn fx:id="colLastName" prefWidth="200" text="Nom" />
                  <TableColumn fx:id="colAge" prefWidth="100" text="Âge" />
                  <TableColumn fx:id="colGrade" prefWidth="100" text="Note / 20" />
               </columns>
               <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </center>
</BorderPane>