<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.StudentController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Gestion des Étudiants (LP Tracker)" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
    
    <GridPane hgap="10" vgap="10">
        <TextField fx:id="fNameInput" promptText="Prénom" GridPane.columnIndex="0" GridPane.rowIndex="0" HBox.hgrow="ALWAYS"/>
        <TextField fx:id="lNameInput" promptText="Nom" GridPane.columnIndex="1" GridPane.rowIndex="0" HBox.hgrow="ALWAYS"/>
        <TextField fx:id="ageInput" promptText="Âge" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="gradeInput" promptText="Note" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    </GridPane>
    
    <HBox spacing="10">
        <Button text="➕ Ajouter" onAction="#handleAddStudent" 
                maxWidth="Infinity" HBox.hgrow="ALWAYS" 
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;"/>
        
        <Button text="🔄 Modifier" onAction="#handleUpdateStudent" 
                maxWidth="Infinity" HBox.hgrow="ALWAYS" 
                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;"/>
        
        <Button text="🗑️ Supprimer" onAction="#handleDeleteStudent" 
                maxWidth="Infinity" HBox.hgrow="ALWAYS" 
                style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-font-weight: bold;"/>
        
    </HBox>

    <HBox spacing="10">
        <Button text="📥 Exporter en CSV" onAction="#handleExportCSV" 
                maxWidth="Infinity" HBox.hgrow="ALWAYS" 
                style="-fx-background-color: #607D8B; -fx-text-fill: white; -fx-font-weight: bold;"/>
        
        <Button text="🚪 Déconnexion" onAction="#handleLogout" 
                maxWidth="Infinity" HBox.hgrow="ALWAYS" 
                style="-fx-background-color: #37474F; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>
    <HBox spacing="10">
    <Button text="📥 Importer CSV" onAction="#handleImportCSV" 
            maxWidth="Infinity" HBox.hgrow="ALWAYS" 
            style="-fx-background-color: #795548; -fx-text-fill: white; -fx-font-weight: bold;"/>
    
    <Button text="📄 Rapport HTML" onAction="#handleExportHTML" 
            maxWidth="Infinity" HBox.hgrow="ALWAYS" 
            style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>
    
    <Separator/>
    
    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10;">
    <TextField fx:id="searchFirstNameField" promptText="Prénom..." 
               onKeyReleased="#handleAdvancedSearch" prefWidth="150"/>
    
    <TextField fx:id="searchLastNameField" promptText="Nom..." 
               onKeyReleased="#handleAdvancedSearch" prefWidth="150"/>
    
    <ComboBox fx:id="ageFilterCombo" promptText="Âge" 
              onAction="#handleAdvancedSearch" prefWidth="80"/>
    
    <Button text="Réinitialiser" onAction="#handleResetFilters" 
            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>
    
    <TableView fx:id="studentTable" VBox.vgrow="ALWAYS" prefHeight="300" onMouseClicked="#handleTableClick">
    <columns>
        <TableColumn fx:id="colFirstName" text="Prénom" prefWidth="150"/>
        <TableColumn fx:id="colLastName" text="Nom" prefWidth="150"/>
        <TableColumn fx:id="colAge" text="Âge" prefWidth="80"/>
        <TableColumn fx:id="colGrade" text="Note" prefWidth="100"/>
    </columns>
    <columnResizePolicy>
        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
    </columnResizePolicy>
</TableView>
<HBox spacing="20" alignment="CENTER" minHeight="50.0" prefHeight="50.0">
    <padding>
        <Insets top="10" bottom="10"/>
    </padding>
    
    <Button text="⬅️ Précédent" onAction="#handlePrevPage" 
            style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-cursor: hand;"/>
            
    <Label fx:id="pageLabel" text="Page 1" 
           style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;"/>
    
    <Button text="Suivant ➡️" onAction="#handleNextPage" 
            style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-cursor: hand;"/>
</HBox>
<Label fx:id="statsLabel" 
       text="Chargement des stats..." 
       wrapText="true" 
       maxWidth="600"
       style="-fx-font-style: italic; -fx-text-fill: #555; -fx-padding: 10 0 0 0;" />
</VBox>