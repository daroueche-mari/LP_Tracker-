<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.StudentController">
   
   <left>
      <VBox spacing="20.0" style="-fx-background-color: #e67e22;" prefWidth="250.0">
         <padding><Insets top="30" right="15" bottom="20" left="15"/></padding>
         <children>
            <Label text="LP TRACKER" textFill="WHITE">
               <font><Font name="System Bold" size="24.0" /></font>
               <VBox.margin><Insets bottom="30" /></VBox.margin>
            </Label>
            
            <Button onAction="#handleExportCSV" prefWidth="220" 
                    style="-fx-background-color: #d35400; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5;" 
                    onMouseEntered="#handleHoverEnterSide" onMouseExited="#handleHoverExitSide" text="📥 Exporter CSV" />
            
            <Button onAction="#handleImportCSV" prefWidth="220" 
                    style="-fx-background-color: #d35400; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5;" 
                    onMouseEntered="#handleHoverEnterSide" onMouseExited="#handleHoverExitSide" text="📤 Importer CSV" />
            
            <Button onAction="#handleExportHTML" prefWidth="220" 
                    style="-fx-background-color: #d35400; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5;" 
                    onMouseEntered="#handleHoverEnterSide" onMouseExited="#handleHoverExitSide" text="📄 Rapport HTML" />
            
            <Region VBox.vgrow="ALWAYS" />
            <Label fx:id="statsLabel" textFill="WHITE" wrapText="true" style="-fx-font-size: 12;" />
            
            <Button onAction="#handleLogout" prefWidth="220" 
                    style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" 
                    onMouseEntered="#handleHoverEnterLogout" onMouseExited="#handleHoverExitLogout" text="🚪 Déconnexion" />
         </children>
      </VBox>
   </left>
  <center>
   <VBox spacing="20.0" style="-fx-background-color: #f4f7f6;">
      <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>
      <children>
         
         <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <children>
               <Label text="Gestion de l'étudiant" textFill="#2c3e50" style="-fx-font-weight: bold; -fx-font-size: 16;"/>
               <GridPane hgap="15" vgap="15">
                  <children>
                     <TextField fx:id="fNameInput" promptText="Prénom" GridPane.columnIndex="0" GridPane.rowIndex="0" prefHeight="35"/>
                     <TextField fx:id="lNameInput" promptText="Nom" GridPane.columnIndex="1" GridPane.rowIndex="0" prefHeight="35"/>
                     <TextField fx:id="ageInput" promptText="Âge" GridPane.columnIndex="0" GridPane.rowIndex="1" prefHeight="35"/>
                     <TextField fx:id="gradeInput" promptText="Note" GridPane.columnIndex="1" GridPane.rowIndex="1" prefHeight="35"/>
                  </children>
               </GridPane>
               <HBox spacing="10" alignment="CENTER_RIGHT">
                  <Button onAction="#handleDeleteStudent" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="🗑️ Supprimer" />
                  <Button onAction="#handleUpdateStudent" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="🔄 Modifier" />
                  <Button onAction="#handleAddStudent" prefWidth="120" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" text="➕ Ajouter" />
               </HBox>
            </children>
         </VBox>

         <HBox spacing="15.0" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
            <children>
               <VBox spacing="5">
                  <Label text="Prénom" style="-fx-font-size: 11; -fx-text-fill: #7f8c8d;"/>
                  <TextField fx:id="searchFirstName" promptText="Filtrer..." prefWidth="150" style="-fx-background-radius: 5;"/>
               </VBox>

               <VBox spacing="5">
                  <Label text="Nom" style="-fx-font-size: 11; -fx-text-fill: #7f8c8d;"/>
                  <TextField fx:id="searchLastName" promptText="Filtrer..." prefWidth="150" style="-fx-background-radius: 5;"/>
               </VBox>

               <VBox spacing="5">
                  <Label text="Âge" style="-fx-font-size: 11; -fx-text-fill: #7f8c8d;"/>
                  <ComboBox fx:id="ageFilterCombo" prefWidth="100" style="-fx-background-radius: 5;"/>
               </VBox>

               <Region HBox.hgrow="ALWAYS" />

               <Button onAction="#handleResetFilters" text="🔄 Réinitialiser" prefHeight="35"
                       style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5; -fx-font-weight: bold;"/>
            </children>
         </HBox>

         <TableView fx:id="studentTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10;" onMouseClicked="#handleTableClick">
            <columns>
               <TableColumn fx:id="colFirstName" text="Prénom" />
               <TableColumn fx:id="colLastName" text="Nom" />
               <TableColumn fx:id="colAge" text="Âge" />
               <TableColumn fx:id="colGrade" text="Note / 20" />
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
         </TableView>
      </children>
   </VBox>
</center>
</BorderPane>