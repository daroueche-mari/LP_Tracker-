<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="800.0" spacing="30.0" 
      style="-fx-background-color: #2c3e50;" xmlns="http://javafx.com/javafx/8.0.171" 
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.WelcomeController">
   <children>
      <Label text="BIENVENUE SUR LP TRACKER" textFill="WHITE">
         <font>
            <Font name="System Bold" size="36.0" />
         </font>
      </Label>
      
      <Label text="Gérez vos étudiants en toute simplicité" textFill="#bdc3c7">
         <font>
            <Font size="18.0" />
         </font>
      </Label>

      <VBox alignment="CENTER" spacing="15.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleGoToLogin" prefHeight="50.0" prefWidth="300.0" 
                    style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-background-radius: 25; -fx-cursor: hand;" text="SE CONNECTER">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
            </Button>
            
            <Button mnemonicParsing="false" onAction="#handleGoToRegister" prefHeight="50.0" prefWidth="300.0" 
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 25; -fx-cursor: hand;" text="CRÉER UN COMPTE">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
            </Button>
         </children>
      </VBox>
   </children>
</VBox>